generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  INVITED
  DISABLED
}

enum WorkspaceStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum BillingPlanKey {
  BASIC
  GROWTH
  PREMIUM
}

enum BillingStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum FlowModeKey {
  MODE_A
  MODE_B
  MODE_C
}

enum CommunicationChannel {
  EMAIL
  SMS
}

enum DataSourceType {
  GOOGLE_CALENDAR
  OUTLOOK_CALENDAR
  APPOINTMENTS_CSV
  CLIENTS_CSV
  MANUAL_IMPORT
}

enum DataSourceStatus {
  PENDING
  IMPORTED
  CONNECTED
  DISCONNECTED
  ERROR
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum AutomationJobType {
  CONFIRMATION
  REMINDER
  REBOOKING
  REVIEW_REQUEST
  SYNC
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum RecoveryOpportunityStatus {
  OPEN
  CONTACTED
  RECOVERED
  CLOSED
}

enum ReviewRequestStatus {
  PENDING
  SENT
  DELIVERED
  COMPLETED
  FAILED
}

enum MetricsPeriodType {
  DAILY
  WEEKLY
  MONTHLY
}

enum LeadBookingOpportunityStatus {
  OPEN
  READY
  BLOCKED
  BOOKED
  CLOSED
}

enum RevenueLeakType {
  NO_SHOW_REVENUE
  CANCELED_NOT_RECOVERED
  STALE_BOOKED_PROOF
  MISSING_CONTACT
  BOOKING_PATH_BLOCKED
}

enum RevenueLeakSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RevenueLeakStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

enum RevenueLeakConfidence {
  LOW
  MEDIUM
  HIGH
}

enum CanonicalEntityType {
  CUSTOMER
  LEAD
  ESTIMATE
  ACTIVITY
  JOB
  INVOICE
  CHANGE_ORDER
  COST
}

enum RevoryValueBasis {
  OBSERVED
  CALCULATED
  ESTIMATED
  OPERATIONAL
  DATA_QUALITY
}

enum CanonicalImportStatus {
  PENDING_REVIEW
  READY
  COMMITTED
  REJECTED
}

enum QuoteRecoveryFindingType {
  OVERDUE_FOLLOW_UP
  HIGH_VALUE_STALE_QUOTE
  OPEN_ESTIMATE_NO_ACTIVITY
  ESTIMATE_AGING_RISK
  MISSING_OWNER_OR_NEXT_STEP
  RECOVERABLE_LOST_QUOTE
}

enum RevenueRealizationFindingType {
  UNDERBILLING_GAP
  APPROVED_CHANGE_ORDER_NOT_BILLED
  MARGIN_AT_RISK
  SUSPECTED_MISSING_CHANGE_ORDER
  SCOPE_CREEP_REVIEW_CANDIDATE
}

enum RevoryFindingCategory {
  FINANCIAL
  OPERATIONAL
  DATA_QUALITY
}

enum RevoryFindingUrgency {
  LOW
  MEDIUM
  HIGH
}

enum RevoryOfferKey {
  QUOTE_RECOVERY_AUDIT
  STARTER
  GROWTH
  PRO
}

enum RevoryEvidenceMetric {
  AUDIT_CONVERSION
  FIRST_VALUE_SECONDS
  USEFUL_FINDING
  CONFIRMED_RECOVERED_VALUE
  SECOND_READ
  AUDIT_TO_SUBSCRIPTION_CONVERSION
  SUPPORT_MINUTES
  RETENTION_INTENT_30_DAY
  RETENTION_INTENT_60_DAY
  FALSE_POSITIVE_DISPUTE
  PLAN_UPGRADE_INTEREST
  WEEKLY_DECISION_USEFUL
}

enum RevoryEvidenceSource {
  SYSTEM
  CUSTOMER
  FOUNDER
  BILLING
}

enum StripeWebhookProcessingStatus {
  PROCESSING
  PROCESSED
  FAILED
}

enum EntitlementStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum AnalysisRunStatus {
  READY
  COMPLETED
}

enum QuoteRecoveryDisposition {
  NONE
  REVIEWED
  RECOVERED
  FALSE_POSITIVE
}

model User {
  id                         String          @id @default(cuid())
  clerkUserId                String?         @unique
  authProvider               String          @default("clerk")
  authSubject                String?         @unique
  email                      String          @unique
  fullName                   String?
  passwordHash               String?
  passwordUpdatedAt          DateTime?
  passwordResetTokenHash     String?         @unique
  passwordResetExpiresAt     DateTime?
  emailVerifiedAt            DateTime?
  emailVerificationTokenHash String?         @unique
  emailVerificationExpiresAt DateTime?
  status                     UserStatus      @default(ACTIVE)
  sessionVersion             Int             @default(1)
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  ownedWorkspaces            Workspace[]
  triggeredRuns              AutomationRun[] @relation("AutomationTriggeredBy")

  @@map("users")
}

model Workspace {
  id                         String                         @id @default(cuid())
  name                       String
  slug                       String                         @unique
  ownerUserId                String
  status                     WorkspaceStatus                @default(DRAFT)
  defaultCurrency            String                         @default("USD")
  // Active mode effectively used by the workspace after activation.
  activeModeKey              FlowModeKey                    @default(MODE_A)
  // Minimal billing foundation for Stripe Checkout, webhook sync, and plan gating.
  planKey                    BillingPlanKey?
  billingStatus              BillingStatus                  @default(INACTIVE)
  stripeCustomerId           String?                        @unique
  stripeSubscriptionId       String?                        @unique
  stripePriceId              String?
  currentPeriodEnd           DateTime?
  cancelAtPeriodEnd          Boolean                        @default(false)
  createdAt                  DateTime                       @default(now())
  updatedAt                  DateTime                       @updatedAt
  owner                      User                           @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  medSpaProfile              MedSpaProfile?
  activationSetup            ActivationSetup?
  dataSources                DataSource[]
  clients                    Client[]
  appointments               Appointment[]
  automationRuns             AutomationRun[]
  recoveryOpportunities      RecoveryOpportunity[]
  reviewRequests             ReviewRequest[]
  metricsSnapshots           MetricsSnapshot[]
  leadBookingOpportunities   LeadBookingOpportunity[]
  revenueLeaks               RevenueLeak[]                  @relation("WorkspaceRevenueLeaks")
  canonicalImportSessions    CanonicalImportSession[]
  canonicalRecords           CanonicalRecord[]
  savedCanonicalMappings     SavedCanonicalMapping[]
  quoteRecoveryFindings      QuoteRecoveryFinding[]
  revenueRealizationFindings RevenueRealizationFinding[]
  entitlements               WorkspaceEntitlement[]
  analysisRuns               QuoteRecoveryAnalysisRun[]
  dataSettings               WorkspaceDataSettings?
  digestPreference           QuoteRecoveryDigestPreference?
  intelligenceSnapshots      RevenueIntelligenceSnapshot[]
  auditEvents                WorkspaceAuditEvent[]
  evidenceEvents             RevoryEvidenceEvent[]

  @@map("workspaces")
}

model WorkspaceEntitlement {
  id                      String            @id @default(cuid())
  workspaceId             String
  offerKey                RevoryOfferKey
  status                  EntitlementStatus @default(ACTIVE)
  stripeCheckoutSessionId String?           @unique
  stripePaymentIntentId   String?
  stripeSubscriptionId    String?           @unique
  startsAt                DateTime          @default(now())
  endsAt                  DateTime?
  maxAnalysisRuns         Int?
  analysisRunsUsed        Int               @default(0)
  stripeEventCreatedAt    DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  workspace               Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, offerKey, status])
  @@map("workspace_entitlements")
}

model QuoteRecoveryAnalysisRun {
  id                  String            @id @default(cuid())
  workspaceId         String
  importSessionId     String?           @unique
  status              AnalysisRunStatus @default(READY)
  findingSnapshotJson Json
  activeCount         Int               @default(0)
  estimatedValueCents Int               @default(0)
  dataQualityJson     Json
  completedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  workspace           Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("quote_recovery_analysis_runs")
}

model CanonicalImportSession {
  id                                   String                @id @default(cuid())
  workspaceId                          String
  idempotencyKey                       String
  status                               CanonicalImportStatus @default(PENDING_REVIEW)
  sourceFileNamesJson                  Json
  mappingJson                          Json
  dataQualityJson                      Json
  eligibilityJson                      Json
  quoteRecoverySnapshotJson            Json?
  quoteRecoveryDataQualitySnapshotJson Json?
  rowCount                             Int                   @default(0)
  acceptedCount                        Int                   @default(0)
  rejectedCount                        Int                   @default(0)
  committedAt                          DateTime?
  createdAt                            DateTime              @default(now())
  updatedAt                            DateTime              @updatedAt
  workspace                            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  records                              CanonicalRecord[]

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, status, createdAt])
  @@map("canonical_import_sessions")
}

model CanonicalRecord {
  id                      String                 @id @default(cuid())
  workspaceId             String
  importSessionId         String
  entityType              CanonicalEntityType
  sourceSystem            String
  externalId              String
  relationExternalIdsJson Json
  provenanceJson          Json
  payloadJson             Json
  occurredAt              DateTime?
  isActive                Boolean                @default(true)
  supersededAt            DateTime?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  workspace               Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importSession           CanonicalImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, entityType, sourceSystem, externalId])
  @@index([workspaceId, entityType, isActive, occurredAt])
  @@index([workspaceId, importSessionId])
  @@map("canonical_records")
}

model SavedCanonicalMapping {
  id              String              @id @default(cuid())
  workspaceId     String
  entityType      CanonicalEntityType
  sourceSignature String
  sourceSystem    String?
  mappingJson     Json
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, entityType, sourceSignature])
  @@map("saved_canonical_mappings")
}

model QuoteRecoveryFinding {
  id                  String                   @id @default(cuid())
  workspaceId         String
  findingType         QuoteRecoveryFindingType
  status              RevenueLeakStatus        @default(OPEN)
  severity            RevenueLeakSeverity      @default(MEDIUM)
  confidence          RevenueLeakConfidence    @default(MEDIUM)
  valueBasis          RevoryValueBasis
  valueCents          Int?
  currency            String                   @default("USD")
  estimateExternalId  String
  fingerprint         String
  reason              String
  recommendedAction   String
  evidenceJson        Json
  detectedAt          DateTime                 @default(now())
  lastSeenAt          DateTime                 @default(now())
  resolvedAt          DateTime?
  disposition         QuoteRecoveryDisposition @default(NONE)
  recoveredValueCents Int?
  dispositionedAt     DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  workspace           Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, fingerprint])
  @@index([workspaceId, status, detectedAt])
  @@index([workspaceId, findingType, status])
  @@map("quote_recovery_findings")
}

model RevenueRealizationFinding {
  id                     String                        @id @default(cuid())
  workspaceId            String
  findingType            RevenueRealizationFindingType
  category               RevoryFindingCategory
  status                 RevenueLeakStatus             @default(OPEN)
  priority               Int
  urgency                RevoryFindingUrgency
  severity               RevenueLeakSeverity           @default(MEDIUM)
  confidence             RevenueLeakConfidence         @default(MEDIUM)
  valueBasis             RevoryValueBasis
  valueCents             Int?
  currency               String                        @default("USD")
  jobExternalId          String
  changeOrderExternalId  String?
  fingerprint            String
  reason                 String
  formula                String?
  calculationInputsJson  Json
  recommendedAction      String
  evidenceJson           Json
  additiveToExecutiveGap Boolean                       @default(false)
  detectedAt             DateTime                      @default(now())
  lastSeenAt             DateTime                      @default(now())
  resolvedAt             DateTime?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  workspace              Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, fingerprint])
  @@index([workspaceId, status, priority])
  @@index([workspaceId, findingType, status])
  @@index([workspaceId, jobExternalId])
  @@map("revenue_realization_findings")
}

model RevenueIntelligenceSnapshot {
  id                             String    @id @default(cuid())
  workspaceId                    String
  importSessionId                String?
  stateFingerprint               String
  quoteFindingSnapshotJson       Json
  realizationFindingSnapshotJson Json
  segmentSnapshotJson            Json
  quoteEstimatedValueCents       Int       @default(0)
  calculatedBillingGapCents      Int?
  approvedChangeReviewCents      Int?
  marginAtRiskCents              Int?
  operationalCount               Int       @default(0)
  currency                       String?
  createdAt                      DateTime  @default(now())
  workspace                      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, stateFingerprint])
  @@index([workspaceId, createdAt])
  @@map("revenue_intelligence_snapshots")
}

model WorkspaceDataSettings {
  id                    String    @id @default(cuid())
  workspaceId           String    @unique
  retentionDays         Int       @default(365)
  lastExportedAt        DateTime?
  lastAnalysisDeletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_data_settings")
}

model QuoteRecoveryDigestPreference {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  enabled     Boolean   @default(false)
  weekday     Int       @default(1)
  lastSentAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("quote_recovery_digest_preferences")
}

model WorkspaceAuditEvent {
  id           String    @id @default(cuid())
  workspaceId  String
  actorUserId  String?
  action       String
  metadataJson Json
  createdAt    DateTime  @default(now())
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("workspace_audit_events")
}

model RevoryEvidenceEvent {
  id              String               @id @default(cuid())
  workspaceId     String
  metric          RevoryEvidenceMetric
  source          RevoryEvidenceSource
  offerKey        RevoryOfferKey?
  booleanValue    Boolean?
  integerValue    Int?
  amountCents     Int?
  currency        String?
  relatedEntityId String?
  idempotencyKey  String
  notes           String?
  observedAt      DateTime             @default(now())
  createdAt       DateTime             @default(now())
  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, metric, observedAt])
  @@map("revory_evidence_events")
}

model StripeWebhookEvent {
  id           String                        @id
  type         String
  payloadHash  String
  status       StripeWebhookProcessingStatus @default(PROCESSING)
  attemptCount Int                           @default(1)
  lastError    String?
  processedAt  DateTime?
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  @@index([status, updatedAt])
  @@map("stripe_webhook_events")
}

model AuthRateLimitBucket {
  key             String    @id
  attemptCount    Int       @default(0)
  windowStartedAt DateTime  @default(now())
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([blockedUntil])
  @@map("auth_rate_limit_buckets")
}

model MedSpaProfile {
  id           String    @id @default(cuid())
  workspaceId  String    @unique
  brandName    String
  businessType String?
  timezone     String
  phone        String?
  addressLine  String?
  city         String?
  state        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("med_spa_profiles")
}

model ActivationSetup {
  id                 String               @id @default(cuid())
  workspaceId        String               @unique
  currentStep        String               @default("profile")
  selectedTemplate   String?
  primaryChannel     CommunicationChannel @default(EMAIL)
  googleReviewsUrl   String?
  averageDealValue   Decimal?             @db.Decimal(10, 2)
  // Recommended mode suggested by the onboarding wizard before activation.
  recommendedModeKey FlowModeKey?
  isCompleted        Boolean              @default(false)
  activatedAt        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  workspace          Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("activation_setups")
}

model DataSource {
  id                        String                   @id @default(cuid())
  workspaceId               String
  type                      DataSourceType
  name                      String
  status                    DataSourceStatus         @default(PENDING)
  lastSyncAt                DateTime?
  lastImportedAt            DateTime?
  lastImportCompletedAt     DateTime?
  lastImportFileName        String?
  lastImportRowCount        Int                      @default(0)
  lastImportSuccessRowCount Int                      @default(0)
  lastImportErrorRowCount   Int                      @default(0)
  lastImportError           String?
  configJson                Json?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  workspace                 Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clients                   Client[]
  appointments              Appointment[]
  leadBookingOpportunities  LeadBookingOpportunity[]
  revenueLeaks              RevenueLeak[]            @relation("DataSourceRevenueLeaks")

  @@unique([workspaceId, name])
  @@index([workspaceId, type])
  @@index([workspaceId, status])
  @@index([workspaceId, lastImportedAt])
  @@map("data_sources")
}

model Client {
  id                     String                  @id @default(cuid())
  workspaceId            String
  dataSourceId           String?
  externalId             String?
  fullName               String?
  firstName              String?
  lastName               String?
  email                  String?
  phone                  String?
  birthDate              DateTime?
  lastVisitAt            DateTime?
  totalVisits            Int?
  hasLeadBaseSupport     Boolean                 @default(false)
  tagsJson               Json?
  notes                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataSource             DataSource?             @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  appointments           Appointment[]
  recoveryOpportunities  RecoveryOpportunity[]
  reviewRequests         ReviewRequest[]
  leadBookingOpportunity LeadBookingOpportunity?
  revenueLeaks           RevenueLeak[]           @relation("ClientRevenueLeaks")

  // Effective uniqueness applies when externalId is present.
  @@unique([workspaceId, externalId])
  // Application rule for the MVP: at least one of externalId, email, or phone must be present.
  @@index([workspaceId])
  @@index([workspaceId, dataSourceId])
  @@index([workspaceId, email])
  @@index([workspaceId, phone])
  @@index([workspaceId, lastVisitAt])
  @@map("clients")
}

model Appointment {
  id                    String                @id @default(cuid())
  workspaceId           String
  clientId              String
  dataSourceId          String?
  externalId            String?
  status                AppointmentStatus
  serviceName           String?
  scheduledAt           DateTime
  bookedAt              DateTime?
  completedAt           DateTime?
  canceledAt            DateTime?
  providerName          String?
  locationName          String?
  sourceNotes           String?
  estimatedRevenue      Decimal?              @db.Decimal(10, 2)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  workspace             Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client                Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dataSource            DataSource?           @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  recoveryOpportunities RecoveryOpportunity[]
  reviewRequests        ReviewRequest[]
  revenueLeaks          RevenueLeak[]         @relation("AppointmentRevenueLeaks")

  // Effective uniqueness applies when externalId is present.
  @@unique([workspaceId, externalId])
  @@index([workspaceId, clientId])
  @@index([workspaceId, dataSourceId])
  @@index([workspaceId, scheduledAt])
  @@index([workspaceId, status, scheduledAt])
  @@map("appointments")
}

model AutomationRun {
  id                String              @id @default(cuid())
  workspaceId       String
  triggeredByUserId String?
  jobType           AutomationJobType
  status            AutomationRunStatus @default(PENDING)
  modeKey           FlowModeKey?
  payloadJson       Json?
  resultJson        Json?
  scheduledFor      DateTime?
  startedAt         DateTime?
  finishedAt        DateTime?
  errorMessage      String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  triggeredByUser   User?               @relation("AutomationTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, scheduledFor])
  @@index([workspaceId, jobType])
  @@map("automation_runs")
}

model RecoveryOpportunity {
  id             String                    @id @default(cuid())
  workspaceId    String
  clientId       String
  appointmentId  String?
  modeKey        FlowModeKey?
  status         RecoveryOpportunityStatus @default(OPEN)
  reason         String
  estimatedValue Decimal?                  @db.Decimal(10, 2)
  detectedAt     DateTime                  @default(now())
  resolvedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  workspace      Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client         Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment    Appointment?              @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, detectedAt])
  @@index([clientId])
  @@map("recovery_opportunities")
}

model ReviewRequest {
  id            String               @id @default(cuid())
  workspaceId   String
  clientId      String
  appointmentId String?
  modeKey       FlowModeKey?
  status        ReviewRequestStatus  @default(PENDING)
  channel       CommunicationChannel @default(EMAIL)
  requestedAt   DateTime             @default(now())
  deliveredAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client        Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment   Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, requestedAt])
  @@index([clientId])
  @@map("review_requests")
}

model MetricsSnapshot {
  id                        String            @id @default(cuid())
  workspaceId               String
  periodType                MetricsPeriodType
  periodStart               DateTime
  periodEnd                 DateTime
  totalClients              Int               @default(0)
  totalAppointments         Int               @default(0)
  completedAppointments     Int               @default(0)
  appointmentsMonitored     Int               @default(0)
  confirmationRate          Decimal?          @db.Decimal(5, 4)
  estimatedNoShowsPrevented Int               @default(0)
  emptySlotsRecovered       Int               @default(0)
  recoveryOpportunities     Int               @default(0)
  googleReviewsRequested    Int               @default(0)
  reviewRequestsSent        Int               @default(0)
  reviewConversionRate      Decimal?          @db.Decimal(5, 4)
  estimatedRevenueProtected Decimal?          @db.Decimal(10, 2)
  estimatedRevenueRecovered Decimal?          @db.Decimal(10, 2)
  createdAt                 DateTime          @default(now())
  workspace                 Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, periodType, periodStart, periodEnd])
  @@index([workspaceId, periodStart, periodEnd])
  @@map("metrics_snapshots")
}

model LeadBookingOpportunity {
  id                 String                       @id @default(cuid())
  workspaceId        String
  clientId           String                       @unique
  intakeDataSourceId String?
  status             LeadBookingOpportunityStatus @default(OPEN)
  intakeChannel      CommunicationChannel?
  bookingPath        CommunicationChannel?
  mainOfferKey       String?
  intakeSourceType   DataSourceType?
  intakeSourceName   String?
  nextAction         String?
  blockingReason     String?
  handoffOpenedAt    DateTime?
  openedAt           DateTime                     @default(now())
  resolvedAt         DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  workspace          Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client             Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  intakeDataSource   DataSource?                  @relation(fields: [intakeDataSourceId], references: [id], onDelete: SetNull)
  revenueLeaks       RevenueLeak[]                @relation("LeadBookingOpportunityRevenueLeaks")

  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, intakeDataSourceId])
  @@map("lead_booking_opportunities")
}

model RevenueLeak {
  id                              String                  @id @default(cuid())
  workspaceId                     String
  sourceDataSourceId              String?
  relatedClientId                 String?
  relatedAppointmentId            String?
  relatedLeadBookingOpportunityId String?
  leakType                        RevenueLeakType
  severity                        RevenueLeakSeverity     @default(MEDIUM)
  status                          RevenueLeakStatus       @default(OPEN)
  confidence                      RevenueLeakConfidence   @default(MEDIUM)
  estimatedValueCents             Int?
  currency                        String                  @default("USD")
  detectedAt                      DateTime                @default(now())
  sourceWindowStart               DateTime?
  sourceWindowEnd                 DateTime?
  reason                          String
  recommendedAction               String
  evidenceJson                    Json
  providerName                    String?
  serviceName                     String?
  sourceName                      String?
  fingerprint                     String
  resolvedAt                      DateTime?
  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt
  workspace                       Workspace               @relation("WorkspaceRevenueLeaks", fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceDataSource                DataSource?             @relation("DataSourceRevenueLeaks", fields: [sourceDataSourceId], references: [id], onDelete: SetNull)
  relatedClient                   Client?                 @relation("ClientRevenueLeaks", fields: [relatedClientId], references: [id], onDelete: SetNull)
  relatedAppointment              Appointment?            @relation("AppointmentRevenueLeaks", fields: [relatedAppointmentId], references: [id], onDelete: SetNull)
  relatedLeadBookingOpportunity   LeadBookingOpportunity? @relation("LeadBookingOpportunityRevenueLeaks", fields: [relatedLeadBookingOpportunityId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, fingerprint])
  @@index([workspaceId, status, detectedAt])
  @@index([workspaceId, leakType, status])
  @@index([workspaceId, severity, status])
  @@index([workspaceId, confidence])
  @@index([workspaceId, sourceWindowStart, sourceWindowEnd])
  @@index([sourceDataSourceId])
  @@index([relatedClientId])
  @@index([relatedAppointmentId])
  @@index([relatedLeadBookingOpportunityId])
  @@map("revenue_leaks")
}
